{
  "git": {
    "deploymentEnabled": {
      "feature/dual-registration": true
    }
  },
  "github": {
    "autoAlias": true,
    "silent": false
  },
  "functions": {
    "api/boe-search.ts": {
      "maxDuration": 90
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Accept, Origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
